{
  "expo": {
    "name": "Aura AI",
    "slug": "aura-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "aura-ai",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ai.aura.app"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Aura AI needs photo access to read your conversation screenshots."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
